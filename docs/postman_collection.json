{
  "info": {
    "name": "Bharat Sangam Backend API",
    "_postman_id": "0f0ce6d8-8912-468d-8a11-6a4a638963b2",
    "description": "Postman collection for the Bharat Sangam backend. Configure `baseUrl`, `adminToken`, and `volunteerToken` variables before using protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8001" },
    { "key": "adminToken", "value": "" },
    { "key": "volunteerToken", "value": "" },
    { "key": "bookingTypeId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "venueId", "value": "" },
    { "key": "artistId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "ticketCode", "value": "" }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Swagger JSON",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api-docs/openapi.json"
          }
        }
      ]
    },
    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/register"
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/login"
          }
        },
        {
          "name": "Get Cloudinary Signature",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/presign-url"
          }
        },
        {
          "name": "Add Volunteer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Volunteer One\",\n  \"email\": \"volunteer@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/add-volunteer"
          }
        },
        {
          "name": "Login Volunteer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"volunteer@example.com\",\n  \"password\": \"Volunteer123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/login-volunteer"
          }
        }
      ]
    },
    {
      "name": "Booking Types",
      "item": [
        {
          "name": "Create Booking Type",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingType\": \"vip\",\n  \"price\": 1500\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/booking-type"
          }
        },
        {
          "name": "List Booking Types",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/getall-bookingtype?page=1&limit=10"
          }
        },
        {
          "name": "Get Booking Type",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/get-single-bookingtype?b_id={{bookingTypeId}}"
          }
        },
        {
          "name": "Update Booking Type",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingType\": \"premium\",\n  \"price\": 2000\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/booking-type/{{bookingTypeId}}"
          }
        },
        {
          "name": "Delete Booking Type",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/booking-type?b_id={{bookingTypeId}}"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Bhajan Night\",\n  \"picture\": \"https://example.com/category.jpg\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/add-category"
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/getAll-category?page=1&limit=10"
          }
        },
        {
          "name": "Get Category",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/admin/getSingle-category/{{categoryId}}"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Devotional Evening\",\n  \"picture\": \"https://example.com/category-updated.jpg\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/add-category/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Venues",
      "item": [
        {
          "name": "Create Venue",
          "request": {
