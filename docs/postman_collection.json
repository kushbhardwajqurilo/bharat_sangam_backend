            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"venue\": \"Main Hall\",\n  \"address\": \"Varanasi, Uttar Pradesh\",\n  \"image\": \"https://example.com/venue.jpg\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/venue"
          }
        },
        {
          "name": "Get Venue",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/venue/{{venueId}}"
          }
        },
        {
          "name": "Update Venue",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"Ayodhya, Uttar Pradesh\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/venue/{{venueId}}"
          }
        },
        {
          "name": "Delete Venue",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/venue/{{venueId}}"
          }
        }
      ]
    },
    {
      "name": "Artists",
      "item": [
        {
          "name": "Create Artist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"artistName\": \"Raghav Sharma\",\n  \"profileImage\": \"https://example.com/profile.jpg\",\n  \"about\": \"Devotional singer and live performer.\",\n  \"email\": \"artist@example.com\",\n  \"contactNo\": \"9876543210\",\n  \"performanceTime\": \"7:30 PM\",\n  \"instruments\": [\"Vocals\", \"Harmonium\"],\n  \"gallery\": [\n    {\n      \"url\": \"https://example.com/gallery-1.jpg\",\n      \"key\": \"artists/gallery-1\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/artist"
          }
        },
        {
          "name": "List Artists",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/artist/all?page=1&limit=10"
          }
        },
        {
          "name": "Get Artist",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/artist/single/{{artistId}}"
          }
        },
        {
          "name": "Update Artist",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"about\": \"Lead devotional vocalist.\",\n  \"performanceTime\": \"8:15 PM\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/artist/{{artistId}}"
          }
        },
        {
          "name": "Delete Artist",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/artist/{{artistId}}"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventName\": \"Bharat Sangam 2026\",\n  \"venueName\": \"{{venueId}}\",\n  \"date\": \"2026-05-15T00:00:00.000Z\",\n  \"time\": \"06:00 PM\",\n  \"tabs\": [\"Bhajan\", \"Kirtan\"],\n  \"hashTags\": [\"#devotional\", \"#sangam\"],\n  \"bookingType\": \"{{bookingTypeId}}\",\n  \"sponsors\": [\"Sponsor One\"],\n  \"artists\": [\"{{artistId}}\"],\n  \"availableTickets\": 200,\n  \"category\": \"Bhajan Night\",\n  \"homeBanner\": \"https://example.com/home-banner.jpg\",\n  \"eventBanner\": \"https://example.com/event-banner.jpg\",\n  \"description\": \"A devotional cultural evening.\",\n  \"maxSeats\": 200,\n  \"bookedSeats\": 0\n}"
            },
            "url": "{{baseUrl}}/api/v1/event"
          }
        },
        {
          "name": "Latest Event",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/event/latest"
          }
        },
        {
          "name": "Latest Event Capacity",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/event/latest-capacity"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Rahul\",\n  \"email\": \"rahul@gmail.com\",\n  \"eventId\": \"{{eventId}}\",\n  \"totalTicket\": 2,\n  \"phone\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/booking/create-ticket"
          }
        },
        {
          "name": "Ticket Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/booking/ticket-detail?u_id={{ticketCode}}"
          }
        },
        {
          "name": "Verify Ticket",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{volunteerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"allow_user\": 2\n}"
            },
            "url": "{{baseUrl}}/api/v1/booking/ticket-verify?u_id={{ticketCode}}"
          }
        }
      ]
    },
